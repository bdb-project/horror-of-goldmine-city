! Barn wall (floating object)
!----------------------------------------
Object "wall"
with
  name 'wall',
  description "It's old and battered like all the rest.",
  found_in room05 room06,
has scenery;

!========================================
! Room 6: Barn
!========================================
Object room06 "Barn"
with
  description "You managed to enter the barn, but you didn't discover much. Of the grain that was once stored here nothing remains, probably due to the birds that immediately took advantage of the abandonment in which the barn found itself. Bright light bursts from the narrow opening above, too high to be reached without a ladder. A door on the south leads outside.",
  s_to barn_door,
  out_to barn_door,
  u_to
  [;
    if (ladder in self)
      <<Climb ladder>>;
  ],
has light;

!----------------------------------------
! Barn
!----------------------------------------
Object barn "barn" 
with
  name 'barn',
  description "It's old and battered like the farmhouse.",
  found_in room05 room06,
has scenery;

!----------------------------------------
! Old sack
!----------------------------------------
Object sack "old sack" room06
class OpenableContainer
with  
	article "an",
  name 'old' 'sack',
	description 
	[;
		print "It's a sack, useful to hold things like cereals, hay or the like. ";
		<<Search self>>;
	],
  before
  [;
    Empty:
      if (hay in self)
      {
        move hay to location;
        give hay general;
        if (location ~= room08)
        "You empty the sack dropping the hay down.";
      "You empty the sack dropping the hay just under the sign."; 
      }
      if (sawdust in self)
      {
       move sawdust to location;
      print "You drop the sawdust. "; 
      }
      "";
    Receive:
      if ((noun ~= hay) && (noun ~=sawdust))
        "You'd better use the sack for what is meant for.";
  ],
  size 4,
has container openable open;

!----------------------------------------
! John's body
!----------------------------------------
Object john "farmer's body" room06
class Body
with
  article "the",
  parse_name
  [ i;
    while (NextWord() == 'farmer' or 'dead' or 'body' or 'farmer^s' or 'corpse' or 'man')
      i++;
    return i;
  ],
  description "The man looks like he died of starvation. He must have been scared to death to lock himself in here until he died. As a matter of fact, he didn't have to wait for long, judging from the wound on his neck. Sadly, you've seen such a wound before. Your anxiety builds.",
  before
  [;
    Search:
      print "You search the man's pockets ";
      if (barn_key in nothing)
      {
        move barn_key to location;
        scope_modified = true;
        "and find the barn key.";
      }
      print_ret (string)SEARCH_AGAIN;
  ],
  add_to_scope wound,
has animate;

!----------------------------------------
! wound on neck
!----------------------------------------
Object wound "wound on neck" 
with
  name 'wound' 'neck' 'wounds',
  description "The man has suffered from a serious wound on the neck. You've seen these wounds before, in Creek Town.",
has scenery;

