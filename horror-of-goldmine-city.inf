with
  name 'dusty' 'pillow',
  description "It possibly was full of lice, but they must be all dead now without miners to feed on.",
  before
  [;
    Take:
      if (self in room17)
        "You don't need it any more. Just leave it where it is.";
  ],
  size 5,
has;

!========================================
! Room 12: Lumber Yard
!========================================
Object room12 "Lumber Yard"
with
  description "Before the first gold vein was discovered, the wood was the only safe resource of these mountains. Then, after the unleashing of the gold rush, Goldmine City became a famous and very popular place. Now only death can be found here. The only exit is towards the south.",
  s_to
  [;
    if (medium_larva hasnt general)
      StopDaemon(medium_larva);
    return room09;
  ],
  before
  [;
    Hint:
      if (medium_larva hasnt general)
        "Maybe these creature are vulnerable to the fire.";
      "There are no more hints available for this location.";
  ],
!has light;
has;

!----------------------------------------
! Lumber yard (floating object)
!----------------------------------------
Object "lumber yard"
with
  name 'old' 'lumber' 'yard',
  description "It's a facility for storing and processing wood.",
  found_in room12 room09,
has scenery;

!----------------------------------------
! Medium-sized larva
!----------------------------------------
Object medium_larva "medium-sized larva" room12
with
  name 'medium-sized' 'larva',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "It's another of those larvae you had defeated in Creek Town and, now that you've seen it, your suspicions about the ongoing alien menace are confirmed. ";
    if (self hasnt general)
      "This one is bigger than the ones you were used to, and creeps towards you, although very slowly. ";
    else
      "However, this one won't be harming anyone any more.";
  ],
  life
  [;
    Attack:
      if (second == sickle)
        "Attacking the larva with the sickle would mean getting very close to it. It's better to use a different approach.";
      if (torch in player) 
        if (self hasnt general)
        {
          if (second == nothing)
            print "(with the torch)^";
          StopDaemon(self);
          give self general;
          "After the events in Creek Town, you know how these monstrous beings behave. This one moves much more slowly than the others, so you quickly skirt around it and set it on fire. Soon, the creature is dead.";
        }
        else
        "Don't waste your time. It's already dead.";
      "You don't have anything suitable for this task.";
  ],
  before
  [;
    Burn:
      if (torch in player) 
        if (self hasnt general)
        {
          if (second == nothing)
            print "(with the torch)^";
          StopDaemon(self);
          give self general;
          "After the events in Creek Town, you know how these monstrous beings behave. This one moves much more slowly than the others, so you quickly skirt around it and set it on fire. Soon, the creature is dead.";
        }
        else
        "Don't waste your time. It's already dead.";
      "You don't have anything suitable for this task.";
    Take:
      "No way!";
  ],
  daemon
  [;
    self.time_left++;
    if (self.time_left > 1)
      print "^The larva";
    switch (self.time_left)
    {
      2: " is creeping toward you. Be careful.";
      3: " is now very close. It looks like you're about to get attacked.";
      4: StopDaemon(self);
        deadflag = 1;
        " lunges at you, biting your throat. You try in vain to do something to stop it, but now you can no longer avoid the horrible death.";
    }
  ],
  time_left 0,
has animate neuter;

!----------------------------------------
! Large amount of sawdust
!----------------------------------------
Object sawdust "large amount of sawdust" room12
with
  name 'large' 'amount' 'of' 'sawdust' 'dust',
  description 
  [;
    if (medium_larva hasnt general)
      "Maybe you should deal with the larva, first.";
    "It's simply a byproduct of wood processing.";
  ],
  before
  [;
    Take:
      if (medium_larva hasnt general)
        "The horrid creature is in the way. Deal with it first.";
      if (sack notin player)
        "You can't take the sawdust without something where to put it in. You'll end up losing it.";
      move self to sack;
      "You take the sawdust and put it into the sack.";
    Drop:
      move self to location;
      "You take the sawdust and drop it down.";
    Burn:
      "You don't need to burn the sawdust.";
  ],
  size 3,
has;

!----------------------------------------
! Hammer
!----------------------------------------
Object hammer "hammer" room12
with
  name 'heavy' 'sturdy' 'hammer',
  description 
  [;
    if (medium_larva hasnt general)
      "The horrid creature is in the way. Deal with it first.";
    "It's a heavy and sturdy hammer, suitable for heavy works.";
  ],
  before
  [;
    Take:
      if (medium_larva hasnt general)
        "The horrid creature is in the way. Deal with it first.";
  ],
  size 3,
has;

!========================================
! Room 13: Tangle of Bushes and Brambles
!========================================
Object room13 "Thick Vegetation"
with
  description
  [;
    if (bushes notin limbo)
      print "You've entered an incredible tangle of bushes and brambles. The thick vegetation almost covers entirely a ";
    else 
      print "Now that you opened a way through the vegetation you can clearly see a ";  
    "row of rusty tracks, one end of which is closed by a buffer stop while the other disappears towards the south among the vegetation. To the east, you can see the back part of the shack and the window you passed through.";
  ],
  e_to room11,
  in_to room11,
  s_to "You can't proceed south since the tangle of bushes is too thick. You need something to open a way.",
has light;

!----------------------------------------
! Miner's shack back 
!----------------------------------------
Object "miner's shack" room13
with
  name 'old' 'miner^s' 'shack',
  description "This shack was possibly only used to get some rest between one shift and the next, so it's mostly empty.",
has scenery;

!----------------------------------------
! Bushes and brambles
!----------------------------------------
Object bushes "bushes and brambles" room13
with
  name 'incredible' 'tangle' 'bushes' 'brambles',
  description "The tangle of bushes and brambles is so thick that the only way to proceed would be to cut a part of it away.",
  before
  [;
    Attack, Cut:
      if (sickle notin player)
        "You have nothing to cut the bushes with.";
      if (second == nothing && sickle in player)
      {
        print "(with the sickle)^";
        second = sickle;
      }
      if (second == sickle)
      {
        move bushes to limbo;
        move gap to location;
        room13.s_to = room14;
        "You struggle a lot to make your way through the vegetation but, after a while, you open a way and discover an old path running south beside the row of rusty tracks.";
      }  
  ],
has scenery;

!----------------------------------------
! Thick vegetation (floating object)
!----------------------------------------
Object "thick vegetation" 
with
  name 'thick' 'vegetation',
  description "Years of abandonment have caused the vegetation to grow to the point that it's very difficult to move around.",
  before
  [;
    Attack, Cut:
      if (player in room11)
        "You can't cut the vegetation from inside the shack.";
      if (bushes notin limbo)
        "There's just too much of it. Maybe you should concentrate on the bushes";
      else
        "It looks like you already opened a gap in the vegetation.";
  ],
  found_in room11 room13,
has scenery;

!----------------------------------------
! Old path
!----------------------------------------
Object "old path" room13
with
  name 'old' 'path',
  description "Despite the passing of time a path can be seen. It points southbound.",
has scenery;

!----------------------------------------
! row of rusty tracks (floating object)
!----------------------------------------
Object "row of rusty tracks"
with
  name 'row' 'of' 'old' 'rusty' 'tracks',
  description
  [;
    if (location == room13 || location == room14)
      "It's a row of rusty tracks that leads to the mine.";
    "They are used to carry carts full of dirt and rocks up and down the mine.";
  ],
  found_in room13 room14 room15 room16,
has scenery;

!----------------------------------------
! Buffer stop
!----------------------------------------
Object stop "buffer stop" room13
with
  name 'buffer' 'stop',
  description "It's a device meant to prevent railway vehicles from going past the end of a physical section of track.",
has scenery;

!----------------------------------------
! Gap in the vegetation that reveals a path to the south
!----------------------------------------
Object gap "gap in the vegetation" !room13
with
  name 'gap',
  description "It is the way you opened towards the south with your sickle.",
  before
  [;
    Enter:
      PlayerTo(room14);
      rtrue;
  ],
has enterable static;

!========================================
! Room 14: Entrance to Mine
!========================================
Object room14 "Entrance to Mine"
with
  description "You find yourself in front of the entrance to Goldmine City's old mine. Some sturdy, now rotten, planks barely support rocks and soil, while other broken beams lie on the ground, fallen after having given way under the weight of the rocks. A row of rusty tracks enters the mine. The interior of the mine is completely shrouded in darkness. From here you can either enter the mine or go back towards the north.",
  n_to room13,
  s_to room15,
  in_to room15,
has light;

!----------------------------------------
! Entrance
!----------------------------------------
Object "mine entrance" 
with
  name 'entrance',
  description
  [;
    if (player in room14)
      "The entrance leads inside the mine.";
    "You can see the light of day coming in from outside.";
  ],
  found_in room14 room15,
has scenery;

!----------------------------------------
! Mine (floating object)
!----------------------------------------
Object "mine" room14
with
  name 'old' 'goldmine' 'city' 'mine',
  description "It's the famous mine of Goldmine City.",
  before
  [;
    Enter:
      if (self in room14)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room15)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room14 room15,
has scenery;

!----------------------------------------
! Rotten planks
!----------------------------------------
Object rotten_planks "rotten planks" room14
with
  name 'rotten' 'planks',
  description "They form the entrance of the mine, preventing the roof from collapsing. They are rotten and they might break anytime under the heavy load.",
has pluralname scenery;

!----------------------------------------
! Broken beams
!----------------------------------------
Object broken_beams "broken beams" room14
with
  name 'heap' 'of' 'broken' 'beams',
  description "It is a heap of broken beams that have fallen on the ground. ",
  before
  [;
    Search:
      "There is nothing special about the beams.";
  ],
has pluralname scenery;

!========================================
! Room 15: Dark Tunnel
!========================================
Object room15 "Dark Tunnel"
with
  description "You've entered a long, dark tunnel that, towards the north, ends at the entrance of the mine. The tunnel disappears towards the south, swallowed by the darkness. A row of rusty tracks runs along the floor. The floor of the tunnel is slightly sloped.",
  n_to
  [;
    dark_count = 0;
    return room14;
  ],
  s_to room16,
  d_to room16,
  out_to room14,
has;

!----------------------------------------
! Dark tunnel (floating object)
!----------------------------------------
Object "tunnel" 
with
  name 'long' 'dark' 'tunnel' 'ground' 'sloped' 'floor',
  description "The long dark tunnel gently slopes down, penetrating further into the mountain.",
   found_in room15 room17 room18,
has scenery;

!========================================
! Room 16: Bend in Tunnel
!========================================
Object room16 "Bend in Tunnel"
with
  description "In this point the tunnel bends towards the east, and separates in two parts, the second of which proceeds downward. Sitting on the tracks, blocked by a wooden wheel chock, an old trolley seems to be the only way to descend into the mountain. To the north, the tunnel leads to the exit. You can hear the noise of small landslides coming from the east.",
  n_to room15,
  e_to room30,
  s_to "The only way to proceed south is aboard the minecart.",
  before
  [;
    Listen:
      "From the east, you can hear the faint noise of dirt and rocks sliding down.";
    Hint:
      if ((mattress notin trolley) && (pillow notin trolley))
        "Putting something soft inside the trolley could help to absorb shocks during the ride.";
      if (((mattress in trolley) && (pillow notin trolley)) || ((mattress notin trolley) && (pillow in trolley)))
        "You are almost set, but you need something else to proper absorb the ride-induced shocks.";
      "There are no more hints available for this location.";
  ],
has;

!----------------------------------------
! Tunnel (floating object)
!----------------------------------------
Object "bend in tunnel" 
with
  name 'bend' 'in' 'tunnel' 'ramification' 'ramifications',
  description "It is just one of the many ramifications of the mine, a product of the long-lasting excavation process.",
  found_in room16 room20,
has scenery;

!----------------------------------------
! Wheel chock
!----------------------------------------
Object "wooden wheel chock" room16
with
  name 'wooden' 'wheel' 'chock',
  description "It's placed closely against the trolley's wheels to prevent accidental movement. You would need to hit it with something to remove it, thus freeing the trolley.",
  before
  [;
    Take:
      "The chock is stuck under one of the wheels. You try to pull it out, but you soon realise you would hit it with something to remove it.";
    Attack:
      if (hammer notin player)
        "You don't have anything to hit it with.";
      if (player notin trolley)
        "The trolley will gain momentum as soon as the chock is removed. You better enter it first.";
      if ((mattress notin trolley) && (pillow notin trolley))
        "It's likely to be a bumpy ride down. You'd better put something inside the cart to protect yourself against injuries.";
      if ((mattress notin trolley) || (pillow notin trolley))
        "You need to put something else inside the cart to protect you, or you may not survive the ride.";
      if (room30 hasnt visited)
        "Maybe you should visit the tunnel to the east first.";
      if (second == nothing)
            print "(with the hammer)^";
      move trolley to room17;
      print "As soon as you hit the chock with the hammer, thus freeing the wheels, the minecart hurtles down the mine tunnel at an increasingly impressive speed, while behind it dangerous landslides produced by the vibrations close the tunnel.^^The flame of your rudimentary torch bends under the strong push of the air.^^With a crash, the trolley hits a rock wall and the impact makes it skid and hit another rock until, slowed down by the series of blows, it ends up stopping and tilting to one side. In the process, you fall out of the trolley.^^If you survived the crashes that stopped the cart's mad rush, it's only due to the protective action of the items you had with you... and a little luck.^^";
      PlayerTo(room17);
      "";
  ],
has scenery;

!----------------------------------------
! Wheels
!----------------------------------------
Object "trolley wheels" room16
with
  name 'wheels' 'wheel',
  description "There's nothing special about the wheels.",
has scenery pluralname;

!----------------------------------------
! Old trolley (in the upper mine)
!----------------------------------------
Object trolley "old trolley" room16
with
  article "an",
  name 'old' 'trolley' 'minecart' 'cart',
  description 
  [;
    if (location == room16)
      print "It's an old minecart. It could possibly lead you to the lower part of the mine. ";
    else
      print "After the bumpy ride the trolley is useless. You are lucky to be still alive. ";
    <<Search self>>;
  ],
  before
  [;
    Take:
      "It's too heavy to be taken.";
    Pull:
      "Although you could pull it, if it gains some momentum you could easily get run over by it.";
    PushDir:
      "The cart can only go one way, so you don't have to specify a direction.";
    Push:
      "If you push it without entering in it first, it'll run down the slope and you will be left with no options to proceed.";    
    Enter:
      if (location == room17)
        "The old cart is tilted on its side, and it's totally useless now.";
      if ((torch notin player) && (torch notin self))
        "If you leave your torch behind you'll never get it back. You don't know what evil lurks in the shadows.";
  ],
has enterable container open;

!========================================
! Room 30: Dead-end tunnel
!========================================
Object room30 "Dead-end tunnel"
with
  description 
  [;
    if (room30 hasnt visited)
      print "As soon you enter the tunnel someone calls out to you. The voice sounds old, tired and suffering.^^";
    "This branch of the tunnels is now a dead-end, due to the recent landslides. When you are done here, you can go back to the main tunnel by going west.";   
  ],
 w_to room16,
 before
 [;
  Listen:
      "The noise of dirt and rocks sliding down is louder here.";
 ],
has;

!----------------------------------------
! Miner's body 
!----------------------------------------
Object miner "miner" room30
class Body
with
  article "a",
  parse_name
  [ nw i;
    nw = NextWord();
    while (nw == 'miner' or 'miner^' or 'miner^s' or 'body')
    {
      i++;
      nw = NextWord();
    }
    return i;
  ],
  description
  [;
    print"He";
    if (self hasnt general)
      print"'s ";
    else 
      print " was ";
    print "one of the miners who works here. ^";
    if (self hasnt general)
      print"^You should talk to him, since he's seriously injured and it looks like he's going to die soon.";
    else
      print"^The guy is dead. The injuries suffered from the larva have been fatal. It's time to leave.";
    "";
  ],
  life
  [;
    Ask: 
      if (self hasnt general)
        "It looks like the man will be dead soon. Just talk to him and let him speak.";
    Talk:
      if (self hasnt general)
      {
        give self general;
        "You introduce yourself very briefly and as soon as the man hears your name he interrupts you and starts talking.^^~You are a god-send, Sir. Not for me, no, but for all the others in danger. Your cousin Alan was right about you, if you made it this far.~^^~What, Alan?~ you reply. But the man stops you and carries on.^^~My time is limited... You need to reach the bottom and destroy what hides down there. The only way down now is by using one of the minecarts, but be very careful since it's gonna be a bumpy ride. Also, the creature that hit me is still there, big but slow. Take care of it before venturing deeper down. Please, save us all.~^^Then, with a last breath, the miner passes away.";
      }
      "Don't you see he's dead? It's time to leave.";
  ],
  before 
  [;
		Search:
			"Let him rest in peace, until the time it'll be possible to give him a proper burial.";
  ],
has animate;

!========================================
! Room 17: Dark Tunnel
!========================================
Object room17 "Dark Tunnel"
with
  description "After the bumpy ride that almost got you killed, you are now at the end of a dark tunnel. It looks like the sections of the mine intersected at different levels, so the next section is below you. Since the tunnel collapsed behind you, the only available direction is down.",
  d_to room18,
has;

!----------------------------------------
! Vault
!----------------------------------------
Object "vault" room17
with
  name 'vault',
  description "You hope the vault holds up a little bit longer, or you'll end up buried alive.",
has scenery;

!========================================
! Room 18: Dark Tunnel
!========================================
Object room18 "Dark Tunnel"
with
  description "The tunnel you're in continues east. The faint light of your torch illuminates the rotten beams on the ceiling, and you hope they can hold the rocky vault a little longer. A row of old tracks runs along the floor. The noise of small landslides that you occasionally hear becomes more intense with every step you take.",
  e_to room19,
  u_to room17,
  before
  [;
    Listen:
      "You occasionally hear the sound of falling rocks.";
  ],
has;

!----------------------------------------
! row of rusty tracks (floating object)
!----------------------------------------
Object "row of rusty tracks"
with
  name 'row' 'of' 'old' 'rusty' 'tracks',
  description
  [;
    "They are used to carry carts full of dirt and rocks up and down the mine.";
  ],
  found_in room18 room19 room20,
has scenery;

!----------------------------------------
! Ceiling (floating object)
!----------------------------------------
Object "ceiling" 
with
  name 'ceiling' 'cracks',
  description "You hope the vault holds up a little bit longer, or you'll end up buried alive.",
  found_in room18 room19 room20,
has scenery pluralname;

!----------------------------------------
! Rotten beams (floating object)
!----------------------------------------
Object "rotten beams" 
with
  name 'rotten' 'beams' 'planks',
  description "They are rotten and probably won't hold the vault much longer.",
  found_in room18 room19 room20,
has scenery pluralname;

!----------------------------------------
! Old trolley 
!----------------------------------------
Object old_trolley "old trolley" room18
with
  article "an",
  name 'old' 'trolley' 'minecart' 'cart',
  description
  [;
    print "It's another of those carts used to work in the mine. "; 
    <<Search self>>;
  ],
  before
  [;
    Take:
      "It's too heavy to be taken.";
    Pull:
      "Although you could pull it, if it gains some momentum you could easily get run over by it.";
    PushDir:
      "The cart can only go one way, so you don't have to specify a direction.";
    Push:
      if (self in room18)
      {
        move self to room19;
        "You push the trolley, which stops a little bit further east.";
      }   
      if (self in room19)
      {
        if (vault hasnt general)
          "You should take care of the vault, first.";
        move self to room20;
        give large_larva general;
        room20.e_to = room21;
        print "You push the trolley, which stops a little bit further east "; 
        if (room20 has visited)
          "after running over the larva and killing it.";
        "after making a weird sound, as if it hit something.";
      }   
  ],
has enterable container open;

!========================================
! Room 19: Intersection in Tunnel
!========================================
Object room19 "Intersection in Tunnel"
with
  description 
  [;
    print "This old, unsafe junction tunnel, used to have exits in the four cardinal directions. The ones to the north and to the south are totally collapsed. The ceiling is crossed by long cracks from which large quantities of dust often fall. A row of old tracks runs along the floor. Along the ceiling, some beams seem too old to resist the weight of the rocky vault of the tunnel, ";
    if (vault hasnt general)
      print"so consider your next move before proceeding eastbound. ";
    else print"but they should be fine now that you reinforced the vault. ";
    "To the west the tunnel continues until it disappears into the darkness.";
  ],
  n_to "You can't go north, since the tunnel is collapsed.",
  s_to "You can't go south, since the tunnel is collapsed.",
  e_to
  [;
    if (vault hasnt general)
    {
      deadflag = 1;
      "Suddenly, as you enter the tunnel, a menacing rumbling makes you look up and the last thing you notice is the mass of debris that, having broken away from the unsafe ceiling of the tunnel, is falling on you. Then everything goes dark. You had been warned!";
    }
    if (large_larva hasnt general)
    {
      large_larva.time_left = 0;
      StartDaemon(large_larva);
    }
    return room20;
  ],
  before
  [;
    Hint:
      if (beam in nothing)
        "Have you searched the heap of building materials?";
      if (vault hasnt general)
        "Have you considered to reinforce vault with the beam?";
      "There are no more hints available for this location.";
  ],
  w_to room18,
has;

!----------------------------------------
! Intersection in tunnel
!----------------------------------------
Object "intersection in tunnel" room19
with
  name 'intersection' 'in' 'old' 'unsafe' 'tunnel',
  description "Actually, it used to be an intersection, but it's now simply a tunnel that runs from west to east.",
has scenery;

!----------------------------------------
! Vault of tunnel
!----------------------------------------
Object vault "vault of tunnel" room19
with
  name 'vault' 'of' 'tunnel' 'ceiling',
  description 
  [; 
    print "It's the vault of the tunnel, and";
    if (self hasnt general)
      " it could collapse any minute.";
    " it looks pretty secure, now that you stuck the wooden beam under it.";
  ],
  before
  [;
    Receive:
      if (noun ~= beam)
        "You can't put that in the vault.";
      if ((beam in player) && (location == room19))
      {
        give beam general;
        give vault general;
        move beam to location;
        "You place the beam under the vault, reinforcing it. It won't collapse any more.";
      }  
  ],
has supporter scenery;

!----------------------------------------
! Heap of building material
!----------------------------------------
Object heap "heap of building materials" room19
with
  parse_name
  [ i;
    while (NextWord() == 'heap' or 'of' or 'building' or 'materials')
      i++;
    return i;
  ],
  description "It's a heap of building material, possibly brought here to reinforce the tunnel.",
  before
  [;
    Search:
      if (beam in nothing)
      {
        move beam to room19;
        "You search the heap of building material and find a wooden beam.";
      }
      "Nope, nothing but junk.";
  ],
has static;

!----------------------------------------
! Beam of wood
!----------------------------------------
Object beam "beam of wood"
with
  name 'beam' 'of' 'wood',
  description 
  [;
    print "A solid piece of wood. ";
    if (self hasnt general)
      "Maybe you can make use of it to reinforce the vault.";
    "It's now stuck under the vault, thus reinforcing it against collapsing.";
  ],
  before
  [;
    Insert:
      if ((self in player) && (location == room19))
      {
        give self general;
        give vault general;
        move beam to location;
        "You place the beam under the vault, reinforcing it. It won't collapse any more.";
      }
    Take:
      if (vault has general)
      {
        give vault ~general;
        give self ~general;
        move self to player;
        "You take the beam. Now the vault could collapse again.";
      }
      else 
      {
        if (self notin player)
        {
          move self to player;
          "You take the beam.";
        }
        "You already have it.";
      }
  ],
  size 5,
has;

!========================================
! Room 20: Dark Tunnel
!========================================
Object room20 "Dark Tunnel"
with
  description "The tunnel you are in right now runs east to west. There's nothing special about it, but you cannot think about how long it took to pierce the rock. A row of old tracks runs along the floor. ",
  e_to "You can't go east while that monster is blocking your way.",
  w_to
  [;
    if (large_larva hasnt general)
      StopDaemon(large_larva);
    return room19;
  ],
has;

!----------------------------------------
! Rock wall
!----------------------------------------
Object "rock wall" room20
with
  name 'rock' 'wall',
  description "You wonder how long it took to pierce the rock to excavate all the tunnels.",
has scenery;

!----------------------------------------
! large-sized larva
!----------------------------------------
Object large_larva "large-sized larva" room20
with
  name 'large-sized' 'larva',
  short_name
  [;
    if (self has general)
      print "dead ";
    rfalse;
  ],
  description
  [;
    print "It's another of those larvae you had defeated at Creek Town. ";
    if (self hasnt general)
      "Yet, this one is bigger and, unlike the ones you've seen so far, looks like a horrible pulsating amoeba-like substance. You'd better keep a distance.";
    else
      "However, this one won't be harming anyone any more.";
  ],
  life
  [;
    Attack:
      if (self hasnt general)
        "This time you have no chance of destroying that monstrosity in hand-to-hand combat. It's better to use a different approach.";
      "Don't waste your time. It's already dead.";
  ],
  before
  [;
    Burn:
      if (self hasnt general)
        "This thing is nasty. You'd better keep some distance.";
      "Don't waste your time. It's already dead.";
    Take:
      "No way!";
  ],
  daemon
  [;
    self.time_left++;
    if (self.time_left > 1)
      print "^The larva";
    switch (self.time_left)
    {
      2: ", possibly 'awakened' by the torchlight, starts moving from the rock wall towards the ground.";
      3: " starts moving toward you. You need to act now!";
      4: StopDaemon(self);
        deadflag = 1;
        " throws itself at you, enveloping you like a death veil. In a few seconds, you die a horrible death by suffocation.";
    }
  ],
  time_left 0,
has animate neuter;

!========================================
! Room 21: End of Tunnel
!========================================
Object room21 "End of Tunnel"
with
  description "You've reached the end of the mining tunnel where a large cavity houses an old elevator, probably working thanks to a series of hidden ropes and pulleys that you can't see. It allows descent to the lowest levels of the mine. Towards the west, the tunnel is lost in darkness.",
  w_to room20,
  e_to room22,
  in_to room22,
has;

!----------------------------------------
! End of tunnel
!----------------------------------------
Object "tunnel" room21
with
  name 'end' 'of' 'mining' 'tunnel',
  description "The tunnel ends here, and the only way out seems to be the elevator.",
has scenery;

!----------------------------------------
! Cavity
!----------------------------------------
Object "cavity"
with
  name 'large' 'cavity',
  description "It has been carved to host the elevator.",
  found_in room21 room23,
has scenery;

!----------------------------------------
! ropes and pulleys (floating object)
!----------------------------------------
Object "ropes and pulleys"
with
  name 'ropes' 'pulleys',
  description "The elevator moves thanks to a mechanism you can't see, so you just hope that those ropes and pulleys are still in good shape to do their job.",
  found_in room21 room22 room23,
has scenery;

!========================================
! Room 22: Old Mining Elevator
!========================================
Object room22 "Old Elevator"
with
  description "You're inside an old elevator. Below you, through the cracks that run between one plank and another, you can see the dark depths of the shaft over which the elevator is suspended. In one corner, a sturdy crank controls the up and down movements.",
  before
  [;
    Go:
      if ((selected_direction == w_to) || (selected_direction == out_to))
      {
        if (crank hasnt general)
        {
          PlayerTo(room21);
        }
        else
        {
          PlayerTo(room23);
        }
        rtrue;
      }
      else
        "You can't go in that direction.";
  ],
has;

!----------------------------------------
! Cracks between planks
!----------------------------------------
Object "cracks" room22
with
  name 'cracks' 'planks' 'dark' 'depths',
  description "The dark depths you can see between one crack and the other are scaring.",
has scenery pluralname;

!----------------------------------------
! Handle
!----------------------------------------
Object crank "crank" room22
with
  parse_name
  [ i;
    while (NextWord() == 'handle' or 'crank')
      i++;
    return i;
  ],
  description "It's a sturdy crank that controls the elevator movement. You can turn the crank clockwise (or right) to go up and anti-clockwise (or left) to go down.",
  before
  [;
    Turn:
      "You'll need to tell me what direction to turn it.";
    TurnLeft:
      if (self  has general)
        "It's already all the way left. It won't go any further.";
      if (self hasnt general)
      {
        give self general;
        "The elevator moves to the lower floor.";
      }
    TurnRight:
      if (self  hasnt general)
        "It's already all the way right. It won't go any further.";
      if (self has general)
      {
        give self ~general;
        "The elevator moves to the upper floor.";
      }
  ],
has scenery;

!----------------------------------------
! Mine elevator (floating object)
!----------------------------------------
Object "elevator" !room22
with
  name 'old' 'mine' 'elevator',
  description
  [;
    if (player in room22)
      "The old elevator shakes at every move you do. You hope it holds up just a little longer.";
    "The elevator looks like it has seen better days, but there are no other ways to move up and down.";
  ],
  before
  [;
    Enter:
      if (self in room21 || self in room23)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room22)
      {
        if (crank hasnt general)
        {
          PlayerTo(room21);
        }
        else
        {
          PlayerTo(room23);
        }
        rtrue;
      }
  ],
  found_in room21 room22 room23,
has scenery;

!========================================
! Room 23: Passage
!========================================
Object room23 "Passage"
with
  description "You're crossing a passage between two, strangely smooth rock walls. To the east, you can see the elevator that took you down here. A row of tracks runs through the passage until they disappear to the west, while the other end seems to disappear to the south into the darkness of a tunnel.",
  s_to room24,
  e_to room22,
  in_to room22,
  w_to
  [;
    if (moving_wall hasnt general)
    {
      moving_wall.time_left = 0;
      StartDaemon(moving_wall);
    }
    return room25;
  ],
  before
  [;
    Touch:
      "The walls are smooth and cool to the touch.";
  ],
has light;

!----------------------------------------
! tracks (floating object)
!----------------------------------------
Object "tracks"
with
  name 'row' 'of' 'tracks',
  description
  [;
    "These tracks are much newer than the others you've found so far.";
  ],
  found_in room23 room24 room25,
has scenery;

!----------------------------------------
! Passage
!----------------------------------------
Object "passage" room23
with
  name 'passage' 'faint' 'light',
  description "Despite not being visible, some source provides enough light to keep moving through the corridors without the need for a torch.",
has scenery;

!----------------------------------------
! Smooth walls 
!----------------------------------------
Object "walls" room23
with
  name 'smooth' 'rock' 'walls' 'stones',
  description "The walls are smooth, as if they had been carved with some extraterrestrial equipment. A faint light illuminates the passage.",
has scenery pluralname;

!========================================
! Room 24: Dead-End Tunnel
!========================================
Object room24 "Dead-End Tunnel"
with
  description "You are now inside yet another dead-end tunnel. The only way out leads back north.",
  n_to room23,
has light;

!----------------------------------------
! Ceiling - lower mine (floating object)
!----------------------------------------
Object ceiling "ceiling" !room18
with
  name 'ceiling',
  description
  [;
    print "It's generally lower than the ones in the upper parts of the mine. ";
    if (player in new_trolley)
        "Since you are inside the trolley you can almost touch it.";
    "";
  ],
  before
  [;
    Touch:
      if (player in new_trolley)
        "You can almost reach it.";
      "You cannot reach the ceiling from where you are.";
  ],
  found_in room23 room24 room25,
has scenery;

!----------------------------------------
! Dead-end tunnel
!----------------------------------------
Object "dead-end passage" room24
with
  name 'dead-end' 'passage',
  description "The tunnel ends here. If an opening was present, it must have been closed, possibly to prevent accidental intrusions from the outside.",
has scenery;

!----------------------------------------
! New trolley 
!----------------------------------------
Object new_trolley "new trolley" room24
with
  article "a",
  name 'new' 'trolley' 'minecart' 'cart',
  description 
  [;
    print "This one is brand new, with a thick frame which gives it a sturdy look. ";
    <<Search self>>;
  ],
  before
  [;
    Take:
      "It's too heavy to be taken.";
    Pull:
      if (self in room24)
        "The trolley is already at the end of the tunnel and can't go further south.";
      if (self in room23)
      {
        move self to room24;
        "You pull the trolley, which stops a little bit further south.";
      }
      if (self in room25)
        "If you pull the trolley the walls will start moving again. Leave it where it is.";
    PushDir:
      "The cart can only go one way, so you don't have to specify a direction.";
    Push:
      if (self in room24)
      {
        move self to room23;
        "You push the trolley, which stops a little bit further north.";
      }   
      if (self in room23)
      {
        move self to room25;
        "You push the trolley, which stops a little bit further west.";
      }
      if (self in room25)
        "It won't go any further.";
    Enter:
      if (location == room25)   
      {
        if (moving_wall hasnt general)
        {
          StopDaemon(moving_wall);
          give moving_wall general;
          move player to new_trolley;
          "You enter inside the trolley just in time to avoid being crushed between the moving wall and the trolley itself. The minecart is robust enough to resist the pressure, and soon the wall stops moving. That was close!";
        }
      }
      else
      {
        move player to new_trolley;
        "You get inside the trolley. Since it's quite big, you notice that you can almost touch the ceiling.";
      } 
    Exit:
      if (moving_wall has general)
        "There is not enough space left around the cart. The stone walls have completely surrounded it. Now the only possible way is up.";
  ],
has enterable container open;

!========================================
! Room 25: Small Room Carved Out of Rock
!========================================
Object room25 "Small Room Carved Out of Rock"
with
  description 
  [;
    print "You're inside yet another small room with smooth walls. ";
    if (moving_wall hasnt general)
      print "You cannot explain the presence of such a room at the bottom of the mine and, besides, you haven't found anything interesting inside. ";
    else 
      print "The room was a subtle deadly trap, but you managed to escape. ";
    "You can see an opening in the ceiling above.";
  ],
  e_to
  [;
    if (moving_wall hasnt general)
      StopDaemon(moving_wall);
    return room23;
  ],
  before 
  [;
    Go:
    if (selected_direction == u_to)
    {
    if ((new_trolley in self) && (player in new_trolley))
    {
      print "Standing inside the trolley is enough to reach the gap in the ceiling, so you pull yourself up and reach another room.^^";
      PlayerTo(room26);
      rtrue;
    }
    "There's an opening above, but you can't reach it.";
    }
  ],
has light;

!----------------------------------------
! Small room
!----------------------------------------
Object "small room" room25
with
  name 'small' 'room',
  description "The only noteworthy thing here is the opening above.",
has scenery;

!----------------------------------------
! Opening in ceiling (floating object)
!----------------------------------------
Object "opening in ceiling"
with
  name 'opening',
  description 
  [;
    if (player in room25) 
      "It's just a little bit above you.";
    if ((player in new_trolley) && (new_trolley in room25))
      "Standing inside the trolley is enough to reach the gap in the ceiling, so you can just go up if you want to reach another room.";
    "You can go back down from where you came.";
  ],
  before
  [;
    Enter:
      if (self in room26)
      {
        "If you want to go down just say so.";
      }
      if ((new_trolley in room25) && (player in new_trolley))
      {
        print "Standing inside the trolley is enough to reach the gap in the ceiling, so you pull yourself up and reach another room.^^";
        PlayerTo(room26);
        rtrue;
      }
      "As hard as you try you can't reach it.";
  ],
  found_in room25 room26,
has scenery;

!----------------------------------------
! Moving wall
!----------------------------------------
Object moving_wall "moving wall" room25
with
  name 'moving' 'wall' 'walls',
  description
  [;
    print "The wall inside the small room ";
    if (self hasnt general)
      "is moving and looks looks like it's going to crush you.";
    else
      "has stopped moving.";
  ],
  daemon
  [;
    self.time_left++;
    print "^The wall";
    switch (self.time_left)
    {
      1: " starts rumbling.";
      2: " is moving toward you. Be careful.";
      3: " is now very close. It looks like you're about to be crushed.";
      4: StopDaemon(self);
        deadflag = 1;
        if (new_trolley notin room25)
          " pushes you against the other end of the room. You try to resist, but the pressure is way too strong to be overcome and you end up horribly crushed between one wall and the other.";
        " pushes you against the trolley. You try to escape, but you soon end up horribly crushed between the trolley and the wall.";
    }
  ],
  time_left 0,
has scenery;

!========================================
! Room 26: Small Room Unrelated to Mining
!========================================
Object room26 "Small Room Unrelated to Mining"
with
  description 
  [;
    print "The room you are in is small and completely empty. ";
    if (self hasnt general)
      print "An intense brightness filters from the walls and no exit is visible, aside from the one taking you down to the mine. ";
    else
      print "After playing the recording the brightness is now much less intense and part of the western wall disappeared, allowing you to proceed west. ";
    if (button has general)
      "Also, the southern wall partially opened revealing the hidden exit. ";
    "";
  ],
  d_to 
  [;
    print "You lower yourself down, back to the mine.^^";
    return new_trolley;
  ],
  n_to "There's no exit towards the north.",
  s_to
  [;
    if (room32 hasnt general)
      "An exit seems be concealed in the southern wall, but you have no idea how to open it.";
    if (alan in self)
    {
      move alan to room33;
      print "Alan follows you.^^";
    }
    return room33;
  ],
  e_to "There's no exit towards the east.",
  w_to
  [;
    if (room26 hasnt general)
      "As you approach the west wall, a flash of bright light blinds you and you are hit by an intense (and very painful) discharge of energy. It feels like being back to Creek Town.";
    if (alan in self)
    {
      move alan to room27;
      print "Alan follows you.^^";
    }
    return room27;
  ],
has light;

!----------------------------------------
! Small room
!----------------------------------------
Object "small room" room26
with
  name 'small' 'room',
  description "It's completely empty.",
has scenery;

!----------------------------------------
! Intense brightness (floating object)
!----------------------------------------
Object intense_brightness "intense brightness" 
with
  article "an",
  name 'intense' 'brightness',
  description 
  [;
    if (room26 hasnt general)
    {
      if (player in room25)
      "It is very bright, and filters through the ceiling.";
    "It is very bright, and filters through the walls. Especially the western one.";
    }
    "The ~intense brightness~ is now much less intense.";
  ],
  found_in room25 room26,
has scenery;

!========================================
! Room 27: Long corridor
!========================================
Object room27 "Long Corridor"
with
  description "This long corridor connects a few different rooms. On each wall, one for every cardinal direction, an exit leads to a different sector. Obviously, you can go back to the small room by going east.",
  n_to
  [;
    if (alan in self)
    {
      move alan to room28;
      print "Alan follows you.^^";
    }
    return room28;
  ],
  s_to
  [;
    if (alan in self)
    {
      move alan to room32;
      print "Alan follows you.^^";
    }
    return room32;
  ],
  e_to
  [;
    if (alan in self)
    {
      move alan to room26;
      print "Alan follows you.^^";
    }
    return room26;
  ],
  w_to
  [;
    if (alan in self)
    {
      move alan to room31;
      print "Alan follows you.^^";
    }
    return room31;
  ],
has light;

!========================================
! Room 28: Detention Sector
!========================================
Object room28 "Detention Sector"
with
  description
  [;
    print "You are inside where the aliens held their victims captive, and you don't want to know what they did to them. ";
    if (room28 hasnt visited)
      print "Yet, the room is clean and well lit.^^At the back of it, inside a cage, is your cousin Alan. You rush to the cell and start shaking it and, when you do so, he wakes up. Thank goodness your lunatic, long-lost, yet truly-beloved cousin is not dead! Upon seeing you, his eyes widen above the warmest smile. You should talk to him. ";
    "The only way out is to the south.";
  ],
  s_to
  [;
    if (alan in self)
    {
      move alan to room27;
      print "Alan follows you.^^";
    }
    return room27;
  ],
has light;

!----------------------------------------
!Detention sector
!----------------------------------------
Object "detention sector" room28
with
  parse_name
  [ i;
    while (NextWord() == 'detention' or 'sector')
      i++;
    return i;
  ],
  description "There's nothing else but the cell here, but the place is scary nonetheless.",
has scenery;

!----------------------------------------
! Cell
!----------------------------------------
Object cell "cage" room28
with
  parse_name
  [ i;
    while (NextWord() == 'cage' or 'prison' or 'cell')
      i++;
    return i;
  ],
  description
  [;
    print "This cage looks like it has held more than one person captive through the years. ";
    <<Search self>>;
  ],
  with_key dummy_key,
has transparent container enterable lockable locked openable static;

!----------------------------------------
! Cousin Alan
!----------------------------------------
Object alan "Alan" cell
with
  parse_name
  [ i;
    while (NextWord() == 'lunatic' or 'long-lost' or 'truly-beloved' or 'beloved' or 'cousin' or 'alan' or 'body')
      i++;
    return i;
  ],
  description
  [;
    "Your long-lost cousin Alan is a tall and handsome guy. Despite all that he's been through, it looks like he's in good shape.";
  ],
  life
  [;
    Talk:
      if (self in cell)
        "~Alan! I finally found you ...~, you hear yourself saying. You should ask him some questions."; 
      "It's not the moment for small talk, now. You'd better escape this deadly mine.";
    Ask:
      wn = consult_from;
      switch (NextWord())
      {
        'alarm', 'system':
          "~It's activated by movement and acts hitting the intruder with a powerful discharge of electricity. Most of the times is lethal.~";
        'alien', 'aliens':
          "~I have no clue how they really look like, since they wear a fake human skin most of the time. I think I saw a clawed hand when they kidnapped me, but I soon passed out and I don't remember much. However, I think they left the place a couple of days ago, after unleashing the final earthquake that buried Goldmine City.~";
        'brightness':
          "~It's just the way those aliens have to signal that the alarm system is active. If you are here, it means you managed to deactivate it.~";
        'button', 'striped':
          if (button notin room32)
            move button to room32;
          "~It's on the consoles. I'm pretty sure it opens all the doors you can find down here. I saw the aliens press it to get out of the mine.~";
        'cell', 'cage':
            if (button notin room32)
            move button to room32;
          "~There's not much to say about it, aside from the obvious fact that it held me captive. It can be opened only from the control room.~";
        'control', 'room', 'controls':
           if (button notin room32)
            move button to room32;
          "~It's full of consoles that I don't know how to operate except, ... there's a striped button on one of them.~ Then Alan stops talking, lost in his thoughts.";
        'console', 'consoles', 'controls':
          if (button notin room32)
            move button to room32;
          "~I don't know how to operate them, but if you press the striped button you should be able to open the cell door, and possibly a way to escape.~";
        'cousin', 'alan', 'kidnap', 'kidnapping':
          "~You guys always thought I was a weirdo and a lunatic. As a matter of fact, I kinda am, but after months of snooping around in Creek Town, I actually discovered what was going on. That's why those aliens kidnapped me. Thank God, they didn't inject me with one of those larvae.~";
        'creek', 'town':
          "~It was a nice little town, before those aliens got there. To be honest, I've never really trusted the loyalty to the institutions of our mayor and part of his team, and when things started to get weird I tried to understand what was going on. You know, a lot of people think I am a weirdo as well, so at the beginning I went unnoticed. But then they got me, and here I am.~";
        'displays', 'monitors':
          "~Don't bother with those. The infomation they show are written in the alien language, so it's impossible to read them.~";
        'door', 'key':
          if (button notin room32)
            move button to room32;
          "~If you mean the cell's door, it can't be open from here with a normal key. Just check the control room.~";
        'earthquake':
          "~That was scary! And actually caused the landslide that buried the city. I don't know how they caused it, but it was probably the effect of something we haven't seen yet.~";
        'equipment', 'incubator':
          print "~It's where they keep and grow those larvae. You must destroy it and kill them all, or we are doomed.~^^";
          if (destroyed_equipment has general)
            " Your cousin Alan smiles when you tell him you already did.";
          "";
        'goldmine', 'gold', 'mine', 'city':
          "~Unlike Creek Town, Goldmine City was totally unappealing as far as its leadership was concerned. I mean, the city council was small and, for the most part, totally not interested in things like wealth and popularity. Yet, as you see, the mine was a perfect place to be used as a hide-out.~";
        'intruder':
          "~Well ... in this case, that would be you.~";
        'larva', 'larvae':
          "~From what I understood, they are parasites capable of getting control of your mind and making you act as the aliens wish. Those larvae would be dangerous regardless, but the aliens have the technology to modify their DNA and behaviour, thus inducing a pre-determined pattern of life in the larva-infected organism.~";
        'me', 'myself':
          "~Hey, I am the weirdo here. You are supposed to know who you are, my dear cousin Murray. But I haven't seen you in a while, and there's a different look in your eyes: much more self-confidence, and a hidden force capable of facing all of this evil.~";
        default:
          "For a moment Alan got lost in his thoughts, and probably didn't hear what you said. Try asking him about something else.";
      }
  ],
  before
  [;
    Take:
      if (self in cell && cell hasnt open)
        "The cage is closed.";
  ],
has animate proper;

!========================================
! Room 29: Cattle Yard
!========================================
Object room29 "Cattle Yard"
with
  description "You find yourself in the centre of a large area used to house the cattle. It's surrounded by a wooden fence, but it's the odour you smell that catches your attention. The only available direction here is east.",
  e_to room01,
  before
  [;
    Smell:
      "Cows are not famous for wearing French perfume, so the smell of livestock is persistent. This is now overtaken by the smell of dead cattle that puts your stomach at stake.";
    Listen:
      "The silence is eerie, apart from the buzz of the flies feasting on the dead cattle.";
  ],
has light;

!----------------------------------------
! Cattle yard
!----------------------------------------
Object "cattle yard" room29
with
  name 'yard',
  description "If there were cattle, they are gone. This place is empty.",
has scenery;

!----------------------------------------
! Dead cattle
!----------------------------------------
Object "dead cattle" room29
with
  article "some",
  name 'dead' 'cattle' 'cows',
  description "Looking at those dead cattle takes your mind back to a few months ago. The feeling of dread, desolation and despair that you experienced in Creek Town is now more present than ever.",
has static pluralname;

!----------------------------------------
! Pile of hay
!----------------------------------------
Object hay "hay" room29
with
  
  article "some",
  name 'hay' 'stack',
  description "It's some of the hay once used to feed the cattle. It's very dry and could burn easily.",
  before
  [;
    Take, Insert:
      if ((sack notin player) && (sack notin location))
        "You can't take the hay without something where to put it in. You'll end up losing it.";
      if (((sack in player) || (sack in location)) && (hay notin sack))
      {
        move hay to sack;
        give self ~general;
        "You take the hay and put it into the sack.";
      }
      "You already have it.";
    Drop:
      move self to location;
      give self general;
      if (location ~= room08)
        "You take the hay and drop it down.";
      "You take the hay and drop it just under the sign.";
    Burn:
      if (self in sack)
        "It's in the sack. You should drop the hay to the ground first.";
      if (lens notin player)
          "You don't have anything to burn the hay with.";
      if (location ~= room08)
          "If you burn it here you will just waste it.";
      if (self has general)
      {
        if (second == nothing)
          print "(with the lens)^";
        move self to limbo;
        move sign to limbo;
        move torch to location;
        "The sun's rays, focused by the lens, soon produce the desired effect on the hay which, by catching fire, also sets fire to the sign. With one of the pole's ends burning, you now have a makeshift, crude lit torch. You have no use for the board, so you throw it away.";
      }
      Search:
        "You search the hay stack hoping to find a pin, but with no luck. Not that you needed one, anyway.";          
  ],
  size 3,
has;

!----------------------------------------
! Torch
!----------------------------------------
Object torch "torch"
with
  name 'crude' 'lit' 'torch' 'dull' 'yellow' 'flame',
  description "It's a crude torch that burns with a dull yellow flame. It looks like it should last for a while.",
  size 5,
has light;

!========================================
! Room 31: Incubator Room
!========================================
Object room31 "Incubator Room"
with
  description 
  [;
    print "You are now inside the incubator room, a bigger version of the one that was concealed inside Creek Town's sacristy. ";
    if (destroyed_equipment in self)
      "The room is a mess, now that you have destroyed the incubator. ";
    "The only exit is towards the east.";
  ],
  e_to
  [;
    if (alan in self)
    {
      move alan to room27;
      print "Alan follows you.^^";
    }
    return room27;
  ],
has light;

!----------------------------------------
! Strange equipment similar to an incubator, in which you glimpse monstrous larvae
!----------------------------------------
Object alien_equipment "strange equipment" room31
with
  article "some",
  name 'strange' 'alien' 'equipment' 'incubator' 'machine',
  description "The strange equipment is similar to an incubator, in which you glimpse monstrous larvae. They are pulsating and moving slowly.",
  before 
  [;
    Take:
      "You can't.";
    Attack:
      if (hammer notin player)
        "I wouldn't do that bare-handed.";
      if (second == nothing)
        print "(with the hammer)^";
      if (self hasnt general)  !give it general after playing Side B
          "While you are preparing to destroy the glass niches in which the monstrous extraterrestrial larvae lie in their strange hibernation, an electronic system, probably designed for their protection, hits you full on with a powerful blast. You are lucky to be still alive.";
      move alien_equipment to limbo;
      move monstrous_larvae to limbo;
      move destroyed_equipment to location;
      move larvae_remains to location;
      give destroyed_equipment general;
      "You smash all the equipment and kill all the larvae.";
  ],
has;

!----------------------------------------
! The monstrous larvae
!----------------------------------------
Object monstrous_larvae "monstrous larvae" room31
with
  name 'monstrous' 'larvae',
  description "They must be the source of the infection. If you were to make an educated guess, you would say these monstrous larvae are ready to infect their host. They are pulsating and moving slowly. You'd better destroy the equipment before it's too late.",
has scenery;

!----------------------------------------
! Destroyed equipment among which you can see the remains of monstrous larvae
!----------------------------------------
Object destroyed_equipment "destroyed alien equipment" 
with
  article "some",
  name 'alien' 'destroyed' 'equipment' 'incubator',
  description "You smashed it all, and you can see the remains of monstrous larvae inside. Is this the end?",
  before
  [;
    Attack:
      "There's nothing to be destroyed any more.";
  ],
has static;

!----------------------------------------
! remains of monstrous larvae
!----------------------------------------
Object larvae_remains "remains of monstrous larvae" 
with
  article "some",
  name 'remains' 'of' 'monstrous' 'larvae',
  description "They won't hurt anyone any more.",
has scenery;

!========================================
! Room 32: Control Room
!========================================
Object room32 "Control Room"
with
  description "Various consoles and displays, possibly used to monitor the status of the facility, are aligned along the walls. For the most part, they show useless information, such as temperature and humidity. Others are unreadable. The only available exit is north.",
  n_to
  [;
    if (alan in self)
    {
      move alan to room27;
      print "Alan follows you.^^";
    }
    return room27;
  ],
  before
  [;
	  Hint:
      "Have you talked to Alan yet?";
  ],
has light;

!----------------------------------------
! Consoles
!----------------------------------------
Object Consoles "consoles" room32
with 
	name 'consoles' 'console',
	description 
  [;
    print "They are used to monitor the functioning of the base, but you cannot understand how to operate them. ";
    if (button in room32)
      "Yet, now that Alan has given you a hint, you know which is the emergency release button. ";
    if (room28 hasnt visited)
      "If you only could find Alan... If he has been held here, he may know something about this stuff.";
    "Maybe Alan knows something about it.";
  ],
has pluralname scenery;

!----------------------------------------
! Displays 
!----------------------------------------
Object Displays "displays" room32
with 
	name 'displays' 'monitors',
	description "They show a lot of data you cannot read or understand.",
has pluralname scenery;

!----------------------------------------
! Emergency release button 
!----------------------------------------
Object button "striped emergency release button"
with
	parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'striped' or 'emergency' or 'cell-door' or 'cell' or 'door' or 'release' or 'button')
    {
      i++;
      if (nw == 'striped')
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description "From the look of it, it's the button Alan was talking about. You guess it's the cell-door release button and hope it unlocks all the other doors too. Maybe it's a kind of emergency button.",
	before [;
		Push:
			if (room31 hasnt visited)
        "Maybe it's better not to press the button until you've explored all the rooms.";
      if (alien_equipment notin limbo)
        "What if it also does something dangerous, like release some poisonous gas or some larvae. Wouldn't it be better to take care of those things first?";
      if (self has general) 
      {
				"You've already unlocked the doors. Pushing it again won't change the situation.";
			}
			else 
      {
				give self general;
				give cell ~locked;
        give cell open;
        move alan to room32;
        room26.s_to = room33;
				print "With a loud click, all the security locks disengage, and the security doors open automatically. A few seconds later Alan reaches you.^";
				rtrue;
			};
		Pull: 
			"It seems it can only be pushed.";
	],
has static;

!========================================
! Room 33: Outside the Mine
!========================================
Object room33 "Outside the Mine"
with 
  description 
  [;
	  deadflag = 2;
    "With a final rush, your cousin and you manage to squeeze through the southern exit before all the machinery in the facility explodes with a huge roar.^^And so, another alien base has been destroyed. More importantly, you've finally found Alan, who doesn't look all that weird to you any more.^^While you are leaving what remains of the blown-up mine, you cannot avoid thinking about what awaits you in the future since the alien menace is yet to be defeated. Maybe you should take RESAT to a new level; maybe it's about time to talk to someone who has the resources to engage a proper war against those creatures. Your spies seem to have heard about something very interesting lately, a secret military organisation called SHADO (Supreme Headquarters Alien Defence Organisation). It's time to pay them a visit...";
  ],
has light;

!========================================
! Limbo
!========================================
Object limbo;

!----------------------------------------
! Dummy key
!----------------------------------------
Object dummy_key;

!========================================
! Printing rules
!========================================
[ consultWord word i;
  for (i=0:i<WordLength(word):i++)
    print (char)LowerCase(WordAddress(word)->i);
];

[ DoesntOrDont obj;
  if (obj has pluralname)
    print "don't";
  else
    print "doesn't";
];

[ firstConsultWord word i;
  for (i=0:i<WordLength(word):i++)
    if (i == 0)
      print (char)UpperCase(WordAddress(word)->i);
    else
      print (char)LowerCase(WordAddress(word)->i);
];

!========================================
! Other routines
!========================================
[ _UpdateDarkness p_silent _ceil _old_darkness _darkness;
  if (location == thedark)
    _old_darkness = true;
  _ceil = ScopeCeiling(player);
  if (_LookForLightInObj(_ceil, _ceil) == false)
    _darkness = true;
  if (_darkness ~= _old_darkness)
    scope_modified = true;
  if (_darkness)
    location = thedark;
  else
    location = real_location;
  if (_darkness ~= _old_darkness && p_silent == false)
  {
    new_line;
    <Look>;
  }
];

[ LowerCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'A' to 'Z': c = c + 32;
    202, 204, 212, 214, 221: c--;
    217, 218: c = c - 2;
    158 to 160, 167, 168, 208 to 210: c = c - 3;
    186 to 190, 196 to 200: c = c - 5 ;
    175 to 180: c = c - 6;
  }
  return c;
];

[ UpperCase c; ! for ZSCII matching ISO 8859-1
  switch (c)
  {
    'a' to 'z': c = c - 32;
    201, 203, 211, 213, 220: c++;
    215, 216: c = c + 2;
    155 to 157, 164, 165, 205 to 207: c = c + 3;
    181 to 185, 191 to 195: c = c + 5 ;
    169 to 174: c = c + 6;
  }
  return c;
];

!========================================
! Grammar
!========================================
Extend 'ask'
  * 'about' topic -> AskAbout;

Extend 'lock' first
  * noun -> Lock;

Extend 'look'
  * 'into' noun -> Search
  * 'behind'/'under' noun -> LookUnder;

Extend 'read' first
  * noun -> Read;

Extend only 'say' first
  * topic -> Say;

Extend only 'speak' replace
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Extend only 'turn'
  * noun 'over' -> Turn
  * 'over' noun -> Turn;

Extend 'turn' first
  * noun 'left'/'anti-clockwise'/'anticlockwise'/'counter-clockwise'/'counterclockwise' -> TurnLeft
  * noun 'to' 'left'/'anti-clockwise'/'anticlockwise'/'counter-clockwise'/'counterclockwise' -> TurnLeft
  * noun 'right'/'clockwise' -> TurnRight
  * noun 'to' 'right'/'clockwise' -> TurnRight;

Verb 'stuck' = 'insert';
Verb 'reinforce' = 'insert';

Extend 'put' 
  * held 'under' noun -> Insert;
Extend 'stuck'
  * held 'under' noun -> Insert;
Extend 'reinforce'
  * noun 'with' held -> Insert reverse;

Extend 'unlock' first
  * noun -> Unlock;

Verb meta 'about' 'info'
  * -> About;

Verb meta 'credits'
  * -> Credits;

Verb ',eject'
  * noun -> Eject;
Verb ',play'
  * noun -> Play;
Verb ',rewind'
  * noun -> Rewind;

Verb meta 'help' 'instructions'
  * -> Help;

Verb 'hint' 'clue'
  * -> Hint;

Verb 'inspect' = 'examine';

Verb 'shake'
  * noun -> Shake;

Verb 'talk' 'babble' 'chat' 'communicate' 'converse' 'gab' 'gossip'
  * -> Talk
  * creature -> Talk
  * noun -> Talk
  * 'to'/'with' creature -> Talk
  * 'to'/'with' noun -> Talk
  * 'to'/'with' creature 'about' topic -> Ask
  * 'to'/'with' noun 'about' topic -> Ask;

Verb 'use'
  * noun -> Use;

Verb 'xyzzy' 'plover' 'plugh' 'yoho'
  * -> MagicWord;

!========================================
! Actions
!========================================
[ AboutSub;
  print "This game is an adaptation of the semi-graphic Italian adventure 'Murray Shannon: L'Orrore di Goldmine City' by Bonaventura Di Bello. It was originally written using The Quill and Illustrator and published by Edizioni Hobby S.r.l. on the cover tape of 'Explorer', no. 8, June 1987 for the Commodore 64 and MSX.^^The data was extracted from the C64 version using UnQuill, translated to English and rewritten for a modern audience with the original author's permission. The new version includes many enhancements that weren't in the original. The coding was done using Inform 6 and the PunyInform library.^^";
  <<Credits>>;
];

[ AskAboutSub x count npc;
  !objectloop (x in location && x has animate && x ~= player)
  ! x && TestScope(x) is needed because Alan is inside the cage (not in the room)
  objectloop (x && TestScope(x) && x has animate && x ~= player)
  {
    count++;
    npc = x;
  }
  if (count == 0)
    "There's no one here to answer your questions.";
  if (count == 1)
    <<Ask npc noun>>;
  "As there are multiple characters here, you'll have to specify who to ask, e.g. ASK MAN ABOUT DOG.";
];

[ CreditsSub;
  "Original concept, game design and coding by Bonaventura Di Bello.^English translation and game skeleton by Garry Francis.^Game redesign and coding by Gianluca Girelli.^Play testing by Robert Eggleston, Garry Francis, RJ Kowalski, Andrew Apted, Pablo Martinez, John Dennis and Melinda.";
];

[ EjectSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't eject ", (ThatOrThose)noun, ".";
];

!Delete GoSub if diagonal directions are used
[ GoSub _prop;
  if (selected_direction == ne_to or nw_to or se_to or sw_to)
    "There are no diagonal directions in this game.";
  _prop = selected_direction;
#Iftrue RUNTIME_ERRORS > RTE_MINIMUM;
  if (_prop == 0)
    return _RunTimeError(ERR_INVALID_DIR_PROP);
#Endif;
  return GoDir(_prop);
];

[ HelpSub;
  "Tell me what to do using simple commands starting with a verb.^^Use LOOK (or L) to refresh the location description. Identify all the objects in the description and EXAMINE (or X) each one. Read responses carefully for hints.^^Use compass directions (N, S, E, W, U and D) to move around. Draw a map as you go.^^Use GET or TAKE to take objects and DROP to drop them again. Use WEAR to wear things like clothing and REMOVE to remove anything that's currently worn. Use INVENTORY (or I) to see what you're carrying and wearing.^^Use AGAIN (or G) to repeat the last command.^^Use UNDO to undo the last command if you make a mistake.^^Use SAVE to save the game and RESTORE to restore it again.^^There are over 100 verbs that you can use, so if something doesn't work, try a different verb or a different way of doing things. Use HINT if you get stuck.^^For full instructions, see the game page at <https://bdb-project.itch.io/horror-of-goldmine-city>.";
];

[ HintSub;
  "Examine everything you find and draw a map.";
];

[ LockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_LOCK_NOT_A_LOCK, 'lock');
    rtrue;
  }
  if (noun has locked)
  {
    PrintMsg(MSG_LOCK_ALREADY_LOCKED);
    rtrue;
  }
  if (noun has open)
  {
    PrintMsg(MSG_LOCK_CLOSE_FIRST);
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to lock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_LOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun locked;
  run_after_routines_msg = MSG_LOCK_DEFAULT;
  run_after_routines_arg_1 = 'lock';
];

[ LookUnderSub;
  if (location == thedark)
    "But it's dark.";
  "You find nothing of interest.";
];

[ MagicWordSub;
  "You use the magic word hoping to summon your cousin, who, of course, doesn't show up. However, it's not the first time where you find yourself in a difficult situation, so after a moment of dismay, you carry on with your quest.";
];

[ PlaySub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't play ", (ThatOrThose)noun, ".";
];

[ ReadSub;
  if (ObjectIsUntouchable(noun, true))
    "I suppose you read tea leaves, too";
  "There's nothing legible on ", (ThatOrThose)noun, ".";
];

[ RewindSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't rewind ", (ThatOrThose)noun, ".";
];

[ SaySub i;
  if (consult_words == 0)
    "You have nothing to say.";
  print "~";
  i = consult_from;
  print (firstConsultWord)i++;
  while (i < consult_from + consult_words)
    print " ", (consultWord)i++;
  print ".~^^";
  wn = consult_from;
  if (consult_words == 1 && NextWord() == 'xyzzy' or 'plover' or 'plugh' or 'yoho')
    <<MagicWord>>;
  if (AfterRoutines())
    return;
  "Nothing happens.";
];

[ ShakeSub;
  if (ObjectIsUntouchable(noun))
    rtrue;
  "You can't shake ", (ThatOrThose)noun, ".";
];

[ TalkSub;
  if (noun == nothing)
    "You start talking to no one in particular.";
  if (noun == player)
    "You start talking to yourself, but it's a one-sided conversation.";
  if (RunLife(noun, ##Talk))
    rtrue;
  print_ret (The)noun, " ", (IsOrAre)noun, " not very talkative.";
];

[ TurnLeftSub;
  <<Turn noun>>;
];

[ TurnRightSub;
  <<Turn noun>>;
];

[ UnlockSub k;
  if (ObjectIsUntouchable(noun))
    return;
  if (noun hasnt lockable)
  {
    PrintMsg(MSG_UNLOCK_NOT_A_LOCK, 'unlock');
    rtrue;
  }
  if (noun hasnt locked)
  {
    PrintMsg(MSG_UNLOCK_ALREADY_UNLOCKED, 'unlock');
    rtrue;
  }
  k = RunRoutines(noun, with_key);
  if (k == nothing)
    "You can't see how to unlock ", (ItOrThem)noun, ".";
  if (second == nothing && k ~= nothing && k in player)
  {
    second = k;
    print "(with ", (the)second, ")^";
  }
  if (second == nothing)
    "You don't have the key.";
  if (second ~= k)
  {
    PrintMsg(MSG_UNLOCK_KEY_DOESNT_FIT);
    rtrue;
  }
  give noun ~locked;
  run_after_routines_msg = MSG_UNLOCK_DEFAULT;
  run_after_routines_arg_1 = 'unlock';
];

[ UseSub;
  if (ObjectIsUntouchable(noun))
    return;
  "You'll have to be more explicit than that.";
];

End;
