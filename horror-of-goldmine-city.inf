with
  description "After a long walk, you've reached the foot of the mountain on which the old mine is probably located. The path that led you here runs south, disappearing among the meadows, and climbs up towards the top of the mountain.",
  n_to room08,
  s_to room01,
  u_to room08,
  before
  [;
