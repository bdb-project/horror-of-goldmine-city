!========================================
! Room 8: Path Up Mountain
!========================================
Object room08 "Path Up Mountain"
with
  description "The path becomes increasingly more perilous, often skirting fearful precipices. However, it's the only way to reach the mine, which must be not very far away. You can go up towards the mountain, or back down towards its foot.",
  u_to room09,
  d_to
  [;
    if (mattress in player)
   {
      move mattress to location;
     print "Since it would be too dangerous (and awkward) to carry the mattress down the mountain, you drop it on the ground.^^";
   }
   return room07;
  ],
  s_to
  [;
    if (mattress in player)
   {
      move mattress to location;
     print "Since it would be too dangerous (and awkward) to carry the mattress down the mountain, you drop it on the ground.^^";
   }
   return room07;
  ],
  before
  [;
    Jump:
      "It's too dangerous to jump, here. You risk to slip and kill yourself.";
    Hint:
      if (sign in self)
        "Maybe a makeshift fire could burn the pole, thus allowing you to take it.";
      "There are no more hints available for this location.";
  ],
has light;

