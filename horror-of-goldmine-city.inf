! Room 11: Miner's Shack
!========================================
Object room11 "Miner's Shack"
with
  description "This old shack was likely used by the miners to get some rest after struggling to retrieve the precious metal in the bowels of the mountain. On the western wall, a broken window allows for a glimpse of the thick vegetation that has invaded the back of the shack. You can reach it by going west, or you can go back to the clearing by going east.",
  e_to room10,
  out_to room10,
  w_to room13,
has light;

!----------------------------------------
! Miner's shack (floating object)
!----------------------------------------
Object "miner's shack"
with
  name 'old' 'miner^s' 'shack',
  description "This shack was possibly only used to get some rest between one shift and the next, so it's mostly empty.",
  before
  [;
    Enter:
      if (self in room10)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room11)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room10 room11,
has scenery;

!----------------------------------------
! western wall
!----------------------------------------
Object "western wall" room11
with
  name 'western' 'wall',
  description "The only noticeable thing on the western wall is the broken window.",
has scenery;

!----------------------------------------
! Window (floating object)
!----------------------------------------
Object window "window" 
with
  name 'broken' 'window',
  description 
  [;
    if (player in room11)  
      "You look out of the window, catching a glimpse of the thick vegetation outside.";
    "You can see the bare interior of the shack.";
  ],
  before
  [;
    Enter:
      if (self in room13)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room11)
      {
        PlayerTo(room13);
        rtrue;
      }
  ],
  found_in room11 room13,
has scenery;

!----------------------------------------
! Old mattress
!----------------------------------------
Object mattress "old mattress" room11
with
  article "an",
  name 'old' 'mattress',
  description "The old mattress lays on the ground, totally worn out. It looks like an army of fleas has selected it as their battleground.",
  before
  [;
    Enter:
      if (self notin player)
      {
        if (verb_word == 'sit' || verb_word == 'stand' || verb_word == 'lie' || verb_word == 'get')
          "Besides being a waste of time, it looks rather uncomfortable.";
      }
      "It would help if you dropped it first.";  
    LookUnder:
      if (self notin player)
        "There's nothing under it.";
      "There was nothing under it last time you checked. There's probably nothing under it even now that it's in your inventory.";
    Take:
      if (self in room17)
        "You don't need it any more. Just leave it where it is.";
  ],
  after
  [;
    Take:
      if (self notin room17)
        "Now that's bulky, isn't it? You hope you don't have to lug it very far.";
  ],
  size 7,
has enterable supporter;

