    Attack:
      "You can't take it this way.";
    Burn:
      "You can't burn it this way. However, if you could start a fire under the sign.";
    Read:
      "It says 'Mine 300 yards', and points uphill.";
    Turn:
      "It can't be turned.";
    Dig:
      "You don't have anything to dig it with.";
    Pull, Push:
      "Neither pulling or pushing it helps here.";
  ],
  add_to_scope pole board,
has static;

