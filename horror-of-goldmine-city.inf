!----------------------------------------
! Old pair of binoculars
!----------------------------------------
Object binoculars "old pair of binoculars" room04
with
  article "an",
  name 'old' 'pair' 'of' 'binoculars',
  description 
  [;
   print "They're an old pair of binoculars. Who might have forgotten them here?";
   if (self has general)
     " Anyway, they are now broken.";
   ""; 
  ],
  before
  [;
    Attack:
      if (self hasnt general)
      {
        move lens to player;
        move binoculars to location;
        give self general;
        "You break the binoculars and take out one of the lenses. Then, you put the lens in your inventory and discard the binoculars.";
      }
      "You already broke the binoculars.";
    Search:
      if (self hasnt general)
        "You look in the binoculars and realise that you can't actually see anything. Still, the lenses could possibly be of some use.";
    Shake:
      if (self hasnt general)
        "When you shake the binoculars you hear the lenses rattling loosely inside.";
      "It appears you've already got what was loosely rattling.";
    Take:
      if (self notin player)
      {
        move self to player;
        if (self hasnt general)
          "While picking them up you hear the lenses rattling loosely inside.";
        "You pick up the binoculars.";
      }
    Wave:
      if (self hasnt general)
        "When you wave the binoculars you hear the lenses rattling loosely inside.";
      "It appears you've already got what was loosely rattling.";
  ],
  add_to_scope lenses,
has pluralname;

!----------------------------------------
! Lenses
!----------------------------------------
Object lenses "lenses"
with
  name 'lenses',
  description 
  [;
    if (binoculars hasnt general)
      "The lenses rattle loosely inside the binoculars. Maybe there's a way to take them out.";
    "What remains inside the binoculars is useless. Don't bother with it.";
  ],
  before
  [;
    Take:
      if (binoculars hasnt general)
        "You can't take the lenses out like this.";
      "There's nothing else to be taken.";
  ]
has scenery pluralname;

!----------------------------------------
! Lens
!----------------------------------------
Object lens "lens"
with
  name 'lens' 'glass',
  description "It's the lens you took from the old binoculars. Your mind goes back to when you were a young scout, and they taught you how to light a fire by concentrating the sun's rays with a lens like this.",
has;

!========================================
! Room 5: Vegetable Garden
!========================================
Object room05 "Vegetable Garden"
with
  description "The small vegetable garden behind the farmhouse shows clear signs of abandonment. Numerous weeds have made their way between the furrows and only a few vegetables still sprout here and there in the middle of the soil, but soon the insects will destroy what little remains. On the northern side of the garden stands a barn, whose entrances are a door and a narrow opening placed very high up. ",
  s_to room03,
  n_to barn_door,
  in_to barn_door,
  u_to
  [;
    if (ladder in self)
      <<Climb ladder>>;
  ],
has light;

!----------------------------------------
! Vegetable garden
!----------------------------------------
Object garden "vegetable garden" room05
with
  parse_name
  [ nw;
    nw = NextWord();
    if (nw == 'vegetable')
    {
      if (NextWord() == 'garden')
        return 2;
      if (TestScope(garden))
        return 0;
      return 1;
    }
    if (nw == 'garden')
      return 1;
    return 0;
  ],
  description "It's full of weeds that have made their way between the furrows. Only a few veggies still sprout here and there.",
has scenery;

!----------------------------------------
! Vegetables
!----------------------------------------
Object veggies "vegetables" room05
with
  name 'vegetables' 'veggies' 'furrows',
  description "No one has taken care of them in a while.",
has scenery pluralname;

!----------------------------------------
! Weeds
!----------------------------------------
Object weeds "weeds" room05
with
  name 'weeds',
  description "Now that no one is attending the garden, they are overgrowing and choking out the vegetables.",
has scenery pluralname;

