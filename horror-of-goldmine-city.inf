! soil
!----------------------------------------
Object soil "soil" room05
with
  name 'soil' 'dirt' 'dust',
  description "The soil looks as if it hasn't been plowed in a while. Occasionally, a gust of wind stirs up a bit of dust.",
  before
  [;
    Dig:
      "Maybe one day you will retire here and become a good farmer, but for the time being you have no time for digging.";
  ]
has scenery;

