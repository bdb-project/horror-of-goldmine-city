!Inform 6 constants
Constant DEATH_MENTION_UNDO;
Constant NO_SCORE;
Constant MAX_FLOATING_OBJECTS 48;

!PunyInform constants
Constant CUSTOM_ABBREVIATIONS;
Constant OPTIONAL_PRINT_SCENERY_CONTENTS;
Constant OPTIONAL_EXTENDED_METAVERBS;
Constant OPTIONAL_EXTENDED_VERBSET;
Constant OPTIONAL_FULL_DIRECTIONS;
Constant OPTIONAL_PROVIDE_UNDO;
Constant RUNTIME_ERRORS 0;!0 for release, 2 for debug

!PunyInform static messages
Constant MSG_COMMENT_NO_TRANSCRIPT "Comment recorded. Use SCRIPT ON to save future comments in a transcript.^";
Constant MSG_COMMENT_TRANSCRIPT "Comment recorded.^";
Constant MSG_PARSER_NO_INPUT "You need to enter a command.";
Constant MSG_PARSER_UNKNOWN_VERB "That's not a verb I recognise.";
Constant MSG_SORRY_DEFAULT "Oh, don't apologise.";
Constant MSG_WAIT_DEFAULT "Time passes...";

!PunyInform dynamic messages
Constant MSG_CLOSE_NOT_OPEN 1000;
Constant MSG_LOCK_ALREADY_LOCKED 1001;
Constant MSG_LOCK_CLOSE_FIRST 1002;
Constant MSG_LOCK_KEY_DOESNT_FIT 1003;
Constant MSG_UNLOCK_ALREADY_UNLOCKED 1004;
Constant MSG_UNLOCK_KEY_DOESNT_FIT 1005;

!Game-specific constants
Constant SEARCH_AGAIN "again, but don't find anything else of interest.";

!Replaced actions
Replace _UpdateDarkness;
Replace GoSub; !Delete if diagonal directions are used
Replace LockSub;
Replace UnlockSub;

Include "globals.h";

!Game-specific variables
Global dark_count 0; !keeps track of how many moves you make in the dark

!========================================
! Entry point routines
!========================================
[ DarkToDark;
  dark_count++;
  if (dark_count > 4)
  {
    deadflag = 1;
	"All of a sudden the ground gives way beneath your feet. You hear yourself screaming while you fall down, but you don't scream for a long time. You hit your head on solid rock, then everything goes silent. Your adventure ends here.";
  }
];

[ LibraryMessages p_msg p_arg_1 p_arg_2;
  switch (p_msg)
  {
    MSG_CLOSE_NOT_OPEN:
      print_ret (CTheyreOrIts)noun, " already closed.";
    MSG_LOCK_ALREADY_LOCKED:
      print_ret (CTheyreOrIts)noun, " already locked.";
    MSG_LOCK_CLOSE_FIRST:
      "You'll have to close ", (ItOrThem)noun, " first.";
    MSG_LOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
    MSG_UNLOCK_ALREADY_UNLOCKED:
      print_ret (CTheyreOrIts)noun, " already unlocked.";
    MSG_UNLOCK_KEY_DOESNT_FIT:
      print_ret (The)second, " ", (DoesntOrDont)second, " fit the lock.";
  }
  p_arg_1 = p_arg_2;
];

[ PrintVerb word;
  if (word == ',eject')
  {
    print "eject";
    rtrue;
  }
  if (word == ',play')
  {
    print "play";
    rtrue;
  }
  if (word == ',rewind')
  {
    print "rewind";
    rtrue;
  }
  rfalse;
];

[ UnknownVerb word;
  if (word == 'eject')
    return ',eject';
  if (word == 'play')
    return ',play';
  if (word == 'rewind')
    return ',rewind';
  return false;
];

Include "puny.h";

!========================================
! Initialisation
!========================================
[ Initialise;
  lookmode = 2;
  move cassette_player to player;
  move cassette to cassette_player;
  no_implicit_actions = true;
  player.description = "You're Murray Shannon, and after the events in Creek Town of some time ago, you're now in Goldmine City still in search of your cousin Alan. You hope he's still alive.";
  thedark.description = "It can be very dangerous to move in the dark.";
  location = room01;
  ! PROLOGUE
  "^Ever since he had saved Earth from the threat of an alien race, Murray Shannon had been living in the constant fear of a second invasion, and for this reason, he had created a special Research Society against Alien Threats: RESAT.^^To keep it secret, he had disguised it as a group of ufologists and parapsychologists scattered throughout the world, who promptly informed him of any inexplicable phenomena that occurred anywhere on Earth.^^One day, a few months after Murray's experiences in Creek Town, one of RESAT's undercover espers contacted Murray about a sequence of events that were occurring in a remote mountain village, known as Goldmine City. A series of seismic shocks were preceded by the appearance of strange lights on the slopes of the mountains, and mysterious sounds could be heard during the nights preceding the earthquakes.^^Murray decided that this was exactly the lead he had been waiting for, so he thanked his psychic friend and immediately left for 'Goldmine City'. After a long drive, he reached a farmhouse in the mine vicinity, ready to face his new enemy and hoping to finally find his long-lost cousin Alan.^";
];

!========================================
! Classes
!========================================
Class Body
with
  life
  [;
    Ask:
      "You're not likely to get an answer from a lifeless body.";
    Attack, ThrowAt:
      "Show some empathy. Allow the dead to rest in peace.";
    Give:
      "Dead bodies aren't normally in the habit of accepting gifts.";
    Kiss:
      "Eww, gross.";
    Show:
      "The dead body shows no interest in ", (the)noun, ". I wonder why.";
    Talk:
      "You strike up a one-sided conversation with the dead body, but it's bored to death.";
    Tell:
      "The corpse listens intently to what you have to say. Or maybe it's not listening at all. It's hard to tell.";
    WakeOther:
      "You give ", (the)noun, " a shake, but it doesn't respond.";
  ],
  before
  [;
    Pull, Push, Take:
      "Let the man rest in peace. You will give him a proper burial in due time.";
  ],
has animate;

Class OpenableContainer
with
  invent
  [;
    if (inventory_stage == 2 && (self hasnt open || child(self) == 0))
      rtrue;
  ],
  before
  [;
    Receive:
      if (noun.size >= self.size)
        print_ret (The)noun, " won't fit in ", (the)self, ".";
  ],
has container openable;

Class OpenContainer
with
  invent
  [;
    if (inventory_stage == 2 && child(self) == 0)
      rtrue;
  ],
  before
  [;
    Receive:
      if (noun.size >= self.size)
        print_ret (The)noun, " won't fit in ", (the)self, ".";
  ],
has container open;

!========================================
! Inventory
!========================================
!----------------------------------------
! Cassette player
!----------------------------------------
Object cassette_player "cassette player"
with
  parse_name
  [ nw i flag;
    nw = NextWord();
    while (nw == 'cassette' or 'tape' or 'player' or 'recorder' or 'buttons')
    {
      i++;
      if (nw == 'cassette' or 'tape' && TestScope(cassette))
        flag++;
      nw = NextWord();
    }
    if (i == flag)
      return 0;
    return i;
  ],
  description
  [;
    print "It's a cassette player for playing cassettes. You found it while searching for your cousin in Creek Town. It has three buttons labeled PLAY, REWIND and EJECT. ";
    <<Search self>>;
  ],
  before
  [;
    LetGo:
      if (noun ~= battery)
        "You can't remove it manually, just press the EJECT button.";
    Receive:
      if (noun == cassette)
        "You'll need to specify whether you want to insert side A or side B.";
      if (noun ~= battery)
        print_ret (The)noun, " won't fit in the cassette player.";
    Drop:
      "This item has proved crucial in Creek Town. You cannot affort dropping and losing it.";
  ],
  add_to_scope play_button eject_button rewind_button,
  size 4,
has container open;

!----------------------------------------
! Play button
!----------------------------------------
Object play_button "play button"
with
  name 'play' 'button',
  description "The play button is labelled 'PLAY'. It's used to play a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      if (battery notin cassette_player)
        "Nothing happens, because there's no battery in the cassette player.";
      if (cassette_player hasnt general)
      {
        !Side A
        if (cassette has general)
          "Nothing happens. The cassette needs to be rewound.";
        give cassette general;
        "The player's motor starts up, with a low hum. Then, from the small speaker, a woman's voice clearly resounds.^^~Whoever you are, God sent you. Earth's destiny is in your hands! As weird as it may seem, we are undergoing an alien invasion. Those invaders are using some kind of larvae to infect human beings and snatch their bodies. Even animals are possibly affected by this unspeakable behaviour.~^^There's a cough, almost a gurgle, then the voice resumes.^^~There is a recording on the other side of this cassette, that corresponds to the sound made by aliens before approaching their own machinery, and which should save you from their automatic protection system.~^^The voice becomes fainter, and pauses for a few second. Then, it starts again.^^~I managed to record it, but the price I had to pay is very high. Now I have little time left to live and I just want to tell you to do your best, because when the damned larvae have grown on the Earth, it will really be over.~^^There's a gasp and then nothing. You listened to this tape a million times, and every time it gives you the shivers.";
      }
      else
      {
        !Side B
        if (cassette hasnt general)
          "Nothing happens. The cassette needs to be rewound.";
        give cassette ~general;
        print "A strange modulated sound comes out of the recorder's speaker. It keeps repeating itself like a kind of mathematical sequence. ";
        ! game specific action
        if ((side_b hasnt general) && (player in room26)) 
        {
          give side_b general;
          !move intense_brightness to limbo;
          give alien_equipment general;
          give room26 general;
          room26.w_to = room27;
          print "Once again, playing the recording did the trick. Part of the western wall disappeared and you can now proceed west.";
        }
        "";
        ! end of action
      }
  ],
has scenery;

!----------------------------------------
! Rewind button
!----------------------------------------
Object rewind_button "rewind button"
with
  name 'rewind' 'button',
  description "The rewind button is labelled 'REWIND'. It's used to rewind a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      if (battery notin cassette_player)
        "Nothing happens, because there's no battery in the cassette player.";
      if (cassette_player hasnt general)
      {
        !Side A
        if (cassette hasnt general)
          "Nothing happens. It must be fully rewound.";
        give cassette ~general;
        "The cassette spins wildly as it rewinds the cassette, then it comes to a stop.";
      }
      else
      {
        !Side B
        if (cassette has general)
          "Nothing happens. It must be fully rewound.";
        give cassette general;
        "The cassette spins wildly as it rewinds the cassette, then it comes to a stop.";
      }
  ],
has scenery;

!----------------------------------------
! EJECT button
!----------------------------------------
Object eject_button "EJECT button"
with
  name 'eject' 'button',
  description "The EJECT button is used to eject a cassette.",
  before
  [;
    Push:
      if (cassette notin cassette_player)
        "Nothing happens, as there's no cassette in the cassette player.";
      move cassette to player;
      print "The cassette pops out and you grab it";
      if (children(player) > MAX_CARRIED)
      {
        print ", but your hands are full and you drop ", (the)(youngest(player));
        move youngest(player) to real_location;
      }
      ".";
  ],
has scenery;

!----------------------------------------
! Cassette
!----------------------------------------
Object cassette "cassette" 
with
  name 'c90' 'cassette' 'tape' 'two' 'sides',
  description
  [;
    print "It's a C90 cassette with two sides labelled Side A and Side B.";
    if (self in cassette_player)
    {
      print " It's currently in the cassette player with side ";
      if (cassette_player hasnt general)
        print "A";
      else
        print "B";
      print " facing up.";
    }
    "";
  ],
  before
  [;
    Drop:
      "This item has proved crucial in Creek Town. You cannot affort dropping and losing it.";
    Eject:
      if (self notin cassette_player)
        "You can only eject the cassette if it's in a cassette player.";
      <<Push eject_button>>;
    Play:
      if (self notin cassette_player)
        "You can only play the cassette if it's in a cassette player.";
      <<Push play_button>>;
    Rewind:
      if (self notin cassette_player)
        "You can only rewind the cassette if it's in a cassette player.";
      <<Push rewind_button>>;
    Turn:
      if (self notin cassette_player)
        rfalse;
      if (cassette_player has general)
        give cassette_player ~general;
      else
        give cassette_player general;
      "You eject the cassette, turn it over and put it back into the cassette player.";
  ],
  add_to_scope side_a side_b,
  size 1,
has;

!----------------------------------------
! Side A
!----------------------------------------
Object side_a "side A"
with
  name 'side' 'a//',
  description
  [;
    if (cassette in cassette_player && cassette_player has general)
      "You can't see side A of the cassette, as it's facing down in the cassette player.";
    else
      "Side A of the cassette is labelled 'play me first'.";
  ],
  before
  [;
    Eject, Play, Rewind:
      <<(action) cassette>>;
    Insert:
      if (second == cassette_player)
      {
        if (cassette in cassette_player)
          "It's already in the cassette player.";
        move cassette to cassette_player;
        give cassette_player ~general;
        "You insert the cassette into the cassette player with side A facing up.";
      }
    Take:
      "That's part of the cassette.";
  ],
has scenery;

!----------------------------------------
! Side B
!----------------------------------------
Object side_b "side B"
with
  name 'side' 'b//',
  description
  [;
    if (cassette in cassette_player && cassette_player hasnt general)
      "You can't see side B of the cassette, as it's facing down in the cassette player.";
    else
      "Side B of the cassette is labelled 'surveillance system disabler'.";
  ],
  before
  [;
    Eject, Play, Rewind:
      <<(action) cassette>>;
    Insert:
      if (second == cassette_player)
      {
        if (cassette in cassette_player)
          "It's already in the cassette player.";
        move cassette to cassette_player;
        give cassette_player general;
        "You insert the cassette into the cassette player with side B facing up.";
      }
    Take:
      "That's part of the cassette.";
  ],
has scenery;

!----------------------------------------
! 9-volt battery
!----------------------------------------
Object battery "9-volt battery" cassette_player
with
  name '9-volt' '9//' 'volt' 'battery',
  description "It's a common power source with a nominal voltage of 9V, often used in portable electronics.",
  before
  [;
    Drop:
      "This item has proved crucial in Creek Town. You cannot affort dropping it and losing it.";
  ],
  size 1,
has;

!========================================
! Room 1: In Front of Farmhouse
!========================================
Object room01 "In Front of Farmhouse"
with
  description "You're in front of an old farmhouse. A large fenced clearing can be seen to the west. To the north a long dusty path leads away from the farm. The farm looks eerily deserted and a bad smell comes from the west. You can go inside the farmhouse or reach the back by going east.",
  n_to
  [;
    if (ladder in player)
    {
      move ladder to location;
      print "Since you don't need the ladder outside the farm, you drop it on the ground.^^";
    }
    return room07;
  ],
  w_to room29,
  e_to room03,
  in_to room02,
  before
  [;
    Smell:
      "A strong smell of death is carried from the west by a light wind.";
  ],
has light;

!----------------------------------------
! Farmhouse (floating object)
!----------------------------------------
Object "farmhouse"
with
  name 'old' 'farmhouse' 'house',
  description "It looks old and unattended, even though someone must have been living here until recently.",
  before
  [;
    Enter:
      if (self in room01)
        <<Go FAKE_IN_OBJ>>;
    Exit:
      if (self in room02)
        <<Go FAKE_OUT_OBJ>>;
  ],
  found_in room01 room02,
has scenery;

!----------------------------------------
! Front of farmhouse
!----------------------------------------
Object "front of farmhouse" room01
with
  name 'front',
  description "It's old and battered. It looks like it could collapse anytime.",
has scenery;

!----------------------------------------
! Back of farmhouse
!----------------------------------------
Object "back of farmhouse" room01
with
  name 'back',
  description "Since you are in front of it, you cannot see the back.",
has scenery;

!----------------------------------------
! Fence (floating object)
!----------------------------------------
Object "fence"
with
  name 'wooden' 'fence',
  description "The fence that surrounds the clearing has seen better days, but it's not something you have to worry about right now.",
  found_in room01 room29,
has scenery;

!----------------------------------------
! Large clearing (floating object)
!----------------------------------------
Object "large clearing"
with
  name 'large' 'fenced' 'clearing' 'area',
  description "It must have been full of life, back in the day. Now it's just death and desolation.",
  found_in room01 room29,
has scenery;

!----------------------------------------
! Farm (floating object)
!----------------------------------------
Object "farm"
with
  name 'farm',
  description "Despite the death and desolation that reign here, it still looks organized. Years of hard work had shaped it well.",
  found_in room01 room02 room03 room04 room05 room06 room29,
has scenery;

!----------------------------------------
! Path to mountain (floating object)
!----------------------------------------
Object "long path"
with
  name 'long' 'dusty' 'path' 'dust',
  description 
  [;
    print "A long dusty path runs north to south towards the mountains. ";
    if (player notin room01)
      "It becomes increasingly more impervious as you proceed.";
    "";
  ],
  found_in room01 room07 room08,
has scenery;

!----------------------------------------
! High mountains (floating object)
!----------------------------------------
Object "high mountains" !room01
with
  name 'high' 'slopes' 'mountains',
  description "The mine that gives Goldmine City its name must be somewhere in those mountains.",
  found_in room01 room07 room08,
has scenery pluralname;

!========================================
! Room 2: Inside Farmhouse
!========================================
Object room02 "Inside Farmhouse"
with
  description "The interior of the farmhouse is a large room that serves both as a kitchen and as a living room. In one corner there's an old fireplace, while a dusty sofa keeps company with a rocking chair on one side of the room. The exit is to the west.",
  out_to room01,
  w_to room01,
has light;

!----------------------------------------
! Room
!----------------------------------------
Object "room" room02
with
  name 'living' 'room' 'kitchen' 'furniture',
  description "There's nothing special about the room or the furniture.",
has scenery;

!----------------------------------------
! Rocking chair
!----------------------------------------
Object rocking_chair "rocking chair" room02
class OpenContainer
with
  name 'old' 'rocking' 'chair',
  description
  [;
    print "This old rocking chair looks like it is used to sit in the shade and relax after a hot day at work. It looks very comfy. ";
    <<Search self>>;
  ],
  before
  [;
    Climb, Enter:
      if (verb_word == 'lie')
        "It's not big enough to lie on.";
      if (verb_word == 'stand')
        "It's not stable enough to stand on.";
      if (child(self) ~= 0)
        "You'll need to clear everything off the chair before you can sit on it.";
      if (player in rocking_chair)
        "You're already sitting on it.";
    Receive:
      if(noun == cassette_player || noun == cassette || noun == battery)
        <<Drop cassette_player>>;
  ],
  after
  [;
    Enter:
      "You sit on the rocking chair.";
    Exit:
      "You get off the rocking chair.";
  ],
  size 3,
has enterable scenery supporter;

!----------------------------------------
! Sofa
!----------------------------------------
Object sofa "sofa" room02
with
  name 'dusty' 'sofa',
  description
  [;
    print "The sofa, albeit dusty, looks very comfy, but it's all messed up and no one has been sitting here for days. ";
    <<Search self>>;
  ],
  before
  [;
    Enter:
      if (verb_word == 'sit')
        "You sit on the sofa to try it. Yep, it sure is comfy, but you have no time to waste sitting around on a sofa, so you stand up again.";
      if (verb_word == 'stand')
        "The sofa might be all messed up, but that doesn't mean you can stand on it in your dirty shoes.";
      <<Sleep>>;
    LookUnder:
      "You doubt a larva is hiding under it but you check anyway, only to discover that no, no larva is present.";
    Receive:
      if(noun == cassette_player || noun == cassette || noun == battery)
        <<Drop cassette_player>>;
  ],
has enterable scenery supporter;

!----------------------------------------
! Cupboard
!----------------------------------------
Object cupboard "cupboard" room02
class OpenableContainer
with
  name 'cupboard',
  description
  [;
    print "It's a somewhat battered cupboard, just like the other furniture here. ";
    <<Search self>>;
  ],
  before
  [;
    LookUnder:
      if (niche has absent)
        "There's something behind the cupboard, but you can't make out what it is.";
      "You moved the cupboard aside and you can now see a niche where the cupboard used to be.";
    Search:
      if (niche has absent)
        "There's something behind the cupboard, but you can't make out what it is.";
    Pull, Push:
      print "You move the cupboard to ";
      if (self hasnt general)
      {
        give self general;
        give niche ~absent;
        MoveFloatingObjects();
        "reveal a niche.";
      }
      else
      {
        give self ~general;
        give niche absent;
        MoveFloatingObjects();
        "cover the niche.";
      }
  ],
  size 5,
has container openable static;

!----------------------------------------
! Fireplace
!----------------------------------------
Object fireplace "fireplace" room02
with
  name 'fireplace',
  description
  [;
    print "It looks like it hasn't been used in a while. ";
    <<Search self>>;
  ],
  before
  [;
    Search:
      "There's nothing useful here.";
  ],
has scenery supporter;

!----------------------------------------
! Niche
!----------------------------------------
Object niche "niche"
class OpenContainer
with
	name 'niche' 'shelf',
	description
	[;
	  print "It's just a small niche. ";
    <<Search self>>;
	],
  found_in room02,
  size 3,
has absent container open scenery;

!----------------------------------------
! Diary
!----------------------------------------
Object diary "diary" niche 
with
  name 'diary',
  description
  [;
    print "There's nothing special about this diary. ";
    if (self hasnt general)
    {
	  "You wonder what was so secret that needed to be hidden.";
	}
    else
      "Enough reading, already. It's time to act.";
  ],
  before
  [;
    Read:
	    if (self in player)
        "'They finally did it. The rumours about an underground secret installation were true, and so were all my suspicions about those monster creatures. Aliens, perhaps.^^Those who tried to warn the authorities or the press have been accused of instigating conspiracy theories. If they were just theories, how come those people disappeared?^^At a certain point, the town's higher-ups realised the true nature of the menace, but they have been killed and the town is now buried under the rocks from the earthquake.^^I am next. They are coming for me. I know it. If someone ever finds these pages, unveil the truth at the bottom of the mine. Please, PLEASE ... exercise extreme caution. The world is at stake.'^^~So my esper at RESAT was right!~, you cannot avoid thinking.";
		  "But you are not holding the diary.";
  ],
  size 2,
has;

!========================================
! Room 3: Back of Farmhouse
!========================================
Object room03 "Back of Farmhouse"
with
  description 
  [;
    "You're at the back of the farmhouse, that doesn't look any better than the front. All around reigns desolation and not a sound can be heard. From here you can go back from where you came by going west, or proceed to the north. ";
  ],
  n_to room05,
  w_to room01,
  u_to
  [;
    if (ladder in self)
      <<Climb ladder>>;
  ],
  before
  [;
    Listen:
      "Only silence can be heard.";
  ],
has light;

!----------------------------------------
! Farmhouse wall
!----------------------------------------
Object "wall" room03
with
  name 'wall',
  description "It's old and battered like all the rest.",
has scenery;

!----------------------------------------
! desolation (floating object)
!----------------------------------------
Object "desolation" 
with
  name 'desolation',
  description "Despite being a bit off the so-called 'beaten paths', the city and its surroundings have always been a pleasant place to live. Now everything is just the shadow of its former self.",
  found_in room01 room03 room04 room29,
has scenery;

!----------------------------------------
! Farmhouse (floating object)
!----------------------------------------
Object "back of farmhouse"
with
  name 'back' 'of' 'farmhouse' 'farm' 'house',
  description "The back of the farmhouse doesn't look any better than its front.",
  found_in room03 room05,
has scenery;

!----------------------------------------
! Ladder
!----------------------------------------
Object ladder "long ladder" room03
with
  name 'long' 'step' 'ladder',
  initial
  [;
    print "A ladder is ";
    if (self in room03)
      print "leaning against the farmhouse wall";
    else if ((self in room05) || (self in room06))
      print "leaning against the barn wall";
    else 
      print "standing on the ground";
    ".";
  ],
  description
  [;
    print "It's a long ladder. It's currently ";
    if (self in player)
      "under your arm.";
    if (self in room03)
      print "leaning against the farmhouse wall";
    else if ((self in room05) || (self in room06))
      print "leaning against the barn wall";
    else 
      print "standing on the ground";
    ".";
  ],
  before
  [;
    Climb:
      if (player in self)
        <<Exit self>>;
      if (player notin self) 
        <Enter self>;
      if ((self in player) && (location == room03))
        "You should drop the ladder to the ground, first.";
      if ((self in room03) && (location == room03))
      {
        print "^After a brief climb you get to the roof.^^";
        PlayerTo(room04, 2);
        return 2; 
      }
      if ((self in player) && (location == room05))
        "You should drop the ladder to the ground, first.";
      if ((self in room05) && (location == room05))
      {
        print "^After a brief climb you enter the opening and fall into the barn.^^";
        PlayerTo(room06, 2);
        return 2;
      }
      if ((self in player) && (location == room06))
        "You should drop the ladder to the ground, first.";
      if ((self in room06) && (location == room06))
      {
        print "^After a brief climb you fall into the garden.^^";
        PlayerTo(room05, 2);
        return 2;
      }
    Go:
      if (selected_direction == n_to)
      {
        if (location == room05)
          print "You climb the ladder and fall into the barn.^^";
          PlayerTo(room06, 2);
          return 2;
          }
      if (selected_direction == d_to)
      {
        <Exit self>;
        return 2;
      }
      print "You'll have to get off the ladder first.^";
      return 2;
  ],
  after
  [;
    Drop:
      give self ~moved;
      if (location == room03)
        "You stand the ladder against the farmhouse wall.";
      if ((location == room05) || (location == room06))
        "You stand the ladder against the barn wall.";
      "You drop it on the ground.";
    Enter:
      rtrue;
    Exit:
      rtrue;
    Take:
      "You take it and tuck it under your arm. It's a bit awkward to carry, so you hope you don't have to lug it very far.";
  ],
  size 5,
has enterable supporter;

!========================================
! Room 4: Roof of Farmhouse
!========================================
Object room04 "Roof of Farmhouse"
with
  description "You're now on top of the farmhouse's roof. From here, you can see the desolation in the surrounding area. In the distance you can see the landslide that buried the city under tons of rocks and dirt. The only possible direction is down.",
  d_to room03,
  before
  [;
    Hint:
      if (binoculars hasnt general)
        "Sometimes things can be broken.";
    Jump:
      "I wouldn't do it if I were you since the roof looks dilapidated.";
  ]
has light;

!----------------------------------------
! Farmhouse - from the room
!----------------------------------------
Object "farmhouse" room04
with
  name 'old' 'farmhouse' 'house',
  description "From up here the farmhouse looks even older and battered. The view on the landslide is disheartening.",
has scenery;

!----------------------------------------
! Roof
!----------------------------------------
Object "roof" room04
with
  name 'old' 'unstable' 'roof',
  description "It looks old and unstable. You'd better go back down as soon as possible.",
has scenery;

