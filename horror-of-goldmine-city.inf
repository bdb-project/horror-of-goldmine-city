Object "narrow opening"
with
  name 'narrow' 'opening',
  description "You can't see through it from ground level.",
  found_in room05 room06,
has scenery;

!----------------------------------------
! Barn door (floating object)
!----------------------------------------
Object barn_door "barn door"
with
  parse_name
  [ nw;
    nw = NextWord();
    if (nw == 'barn')
    {
      if (NextWord() == 'door')
        return 2;
      if (TestScope(barn))
        return 0;
      return 1;
    }
    if (nw == 'door')
      return 1;
    return 0;
  ],
  description
  [;
    print "It's the door to the barn. The door is currently ";
    if (self has open)
      "open.";
    else
      "closed.";
  ],
  door_dir
  [;
    if (self in room05)
      return n_to;
    else
      return s_to;
  ],
  door_to
  [;
    if (self in room05)
      return room06;
    else
      return room05;
  ],
  before
  [;
    Lock:
      if (self hasnt locked)
        "There is no point in locking the barn door again.";
  ],
  with_key barn_key,
  found_in room05 room06,
has door lockable locked openable scenery;

